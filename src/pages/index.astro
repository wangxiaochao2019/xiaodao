---
import { site } from "../config/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentCard from "../components/ContentCard.astro";
import { getPublishedCollections, getPublishedExperiments, getPublishedProjects, getPublishedWorks, getPublishedWriting, selectFeatured } from "../lib/content";

const projects = selectFeatured(await getPublishedProjects(), 3);
const writing = (await getPublishedWriting()).slice(0, 3);
const collections = (await getPublishedCollections()).slice(0, 1);
const recentUpdates = [
  ...(await getPublishedWorks()).map(({ id, data }) => ({ id, title: data.title, description: data.description, publishedAt: data.publishedAt, href: `/works/${id}/`, label: "作品", tags: data.tags })),
  ...(await getPublishedWriting()).map(({ id, data }) => ({ id, title: data.title, description: data.description, publishedAt: data.publishedAt, href: `/writing/${id}/`, label: "思考", tags: data.tags })),
  ...(await getPublishedExperiments()).map(({ id, data }) => ({ id, title: data.title, description: data.description, publishedAt: data.publishedAt, href: `/experiments/${id}/`, label: "实验", tags: data.tags })),
  ...(await getPublishedCollections()).map(({ id, data }) => ({ id, title: data.title, description: data.description, publishedAt: data.publishedAt, href: `/collections/${id}/`, label: "收藏", tags: data.tags })),
].sort((a, b) => b.publishedAt.getTime() - a.publishedAt.getTime() || a.label.localeCompare(b.label, "zh-CN") || a.id.localeCompare(b.id, "en")).slice(0, 5);
---

<BaseLayout>
  <section class="hero page-shell" aria-labelledby="hero-title">
    <p class="eyebrow">作品 · 思考 · 长期实验</p>
    <h1 id="hero-title">{site.hero}</h1>
    <p class="signature">{site.heroSignature}</p>
  </section>

  <section class="operating-system page-shell section-rule" aria-labelledby="operating-system-title">
    <p class="section-index" aria-hidden="true">CORE</p>
    <div class="operating-system-entry">
      <p class="operating-system-label">我的操作系统</p>
      <h2 id="operating-system-title"><a href="/writing/xiaodao-longterm-principles/">晓刀长期主义原则100条</a></h2>
      <p>关于行动、判断、投资、学习、身体、育儿、关系与自由的一套持续更新的个人原则。</p>
      <a class="operating-system-link" href="/writing/xiaodao-longterm-principles/">阅读核心原则 →</a>
    </div>
  </section>

  <section class="introduction page-shell section-rule" aria-labelledby="intro-title">
    <p class="section-index" aria-hidden="true">00</p>
    <div class="section-heading">
      <h2 id="intro-title">这是一个持续生长的档案。</h2>
    </div>
    <p class="lead">用来保存作品、记录思考、追踪长期实验，也持续向世界发出信号。这里不急于给出完整答案，只认真留下那些真实发生的过程。</p>
  </section>

  <section class="archive-section page-shell section-rule" aria-labelledby="projects-title">
    <div class="section-heading">
      <p class="section-index" aria-hidden="true">01</p>
      <h2 id="projects-title">正在进行</h2>
      <p>最近更新的长期项目。</p>
    </div>
    <div class="card-grid card-grid-three">{projects.length ? projects.map(({ id, data }) => <ContentCard headingLevel="h3" title={data.title} description={data.description} publishedAt={data.publishedAt} href={`/projects/${id}/`} label={data.type} status={data.status} tags={data.tags} />) : <p class="empty">内容正在整理中。</p>}</div>
  </section>

  <section class="archive-section page-shell section-rule" aria-labelledby="thoughts-title">
    <div class="section-heading">
      <p class="section-index" aria-hidden="true">02</p>
      <h2 id="thoughts-title">最近思考</h2>
      <p>最近发布的正式写作。</p>
    </div>
    <div class="card-grid card-grid-three">{writing.length ? writing.map(({ id, data }) => <ContentCard headingLevel="h3" title={data.title} description={data.description} publishedAt={data.publishedAt} href={`/writing/${id}/`} label={data.category} tags={data.tags} />) : <p class="empty">内容正在整理中。</p>}</div>
  </section>

  <section class="archive-section page-shell section-rule" aria-labelledby="collections-title">
    <div class="section-heading">
      <p class="section-index" aria-hidden="true">03</p>
      <h2 id="collections-title">最近收藏</h2>
      <p>近期值得留下、以后还会回看的内容。</p>
    </div>
    <div class="card-grid">{collections.length ? collections.map(({ id, data }) => <ContentCard headingLevel="h3" title={data.title} description={data.description} publishedAt={data.publishedAt} href={`/collections/${id}/`} label={`${data.itemCount} 条`} tags={data.tags} />) : <p class="empty">内容正在整理中。</p>}</div>
  </section>

  <section class="archive-section page-shell section-rule" aria-labelledby="updates-title">
    <div class="section-heading">
      <p class="section-index" aria-hidden="true">04</p>
      <h2 id="updates-title">最近更新</h2>
      <p>作品、思考、实验与收藏的最近五条公开记录。</p>
    </div>
    <div class="card-grid">{recentUpdates.length ? recentUpdates.map((entry) => <ContentCard headingLevel="h3" title={entry.title} description={entry.description} publishedAt={entry.publishedAt} href={entry.href} label={entry.label} tags={entry.tags} />) : <p class="empty">内容正在整理中。</p>}</div>
  </section>

  <section class="about page-shell section-rule" aria-labelledby="status-title">
    <div class="section-heading">
      <p class="section-index" aria-hidden="true">05</p>
      <h2 id="status-title">当前状态</h2>
    </div>
    <p>我正在研究 Investor OS 与 AI Agent，推进个人网站和绘本项目，也持续实验 OpenClaw 与个人知识库。<br /><a href="/now/">查看现在正在做什么 →</a></p>
  </section>

  <section class="closing page-shell" aria-label="结束语">
    <p>{site.slogan}</p>
    <p>持续记录，持续创作，持续向世界发出微弱但真实的信号。</p>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(5.5rem, 7vw, 7rem) clamp(4.25rem, 5vw, 5.5rem);
  }

  .eyebrow,
  .meta,
  .status,
  .section-index {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
  }

  .eyebrow {
    margin-bottom: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    letter-spacing: 0.16em;
  }

  h1 {
    max-width: 13.5em;
    margin-bottom: clamp(1.75rem, 3vw, 2.25rem);
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 4.3vw, 4.75rem);
    font-weight: 600;
    line-height: 1.13;
    letter-spacing: -0.035em;
    white-space: pre-line;
  }

  .signature {
    width: min(100%, 58rem);
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-serif);
    font-size: 1.02rem;
    letter-spacing: 0.08em;
    text-align: right;
  }

  .section-rule {
    display: grid;
    grid-template-columns: minmax(9rem, 0.75fr) minmax(0, 2.25fr);
    gap: 1.75rem clamp(2.5rem, 5vw, 4rem);
    padding-block: var(--space-section);
    border-top: 1px solid var(--color-border);
  }

  .introduction .section-index {
    grid-row: 1 / 3;
  }

  .operating-system .section-index {
    align-self: start;
  }

  .operating-system-entry {
    max-width: var(--content-width);
  }

  .operating-system-label {
    margin-bottom: 1rem;
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
  }

  .operating-system-entry h2 {
    margin-bottom: 1rem;
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 2.8vw, 2.7rem);
  }

  .operating-system-entry h2 a {
    color: inherit;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .operating-system-entry > p:not(.operating-system-label) {
    color: var(--color-text-muted);
    font-family: var(--font-serif);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .operating-system-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .lead,
  .about > p {
    max-width: var(--content-width);
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    line-height: 1.75;
  }

  .section-heading h2 {
    margin-bottom: 0.6rem;
    font-family: var(--font-serif);
    font-size: clamp(1.65rem, 2.4vw, 2.25rem);
  }

  .section-heading > p:last-child {
    margin-bottom: 0;
    color: var(--color-text-muted);
  }

  .archive-section .section-heading,
  .about .section-heading {
    grid-column: 1;
  }

  .card-grid,
  .thought-list {
    grid-column: 2;
  }

  .empty { grid-column: 1 / -1; padding: 3rem 1.5rem; border-block: 1px solid var(--color-border); color: var(--color-text-muted); text-align: center; }

  .card-grid {
    display: grid;
    gap: 0;
  }

  .card-grid-three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .archive-card {
    display: flex;
    min-height: 18rem;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-small);
    background: color-mix(in srgb, var(--color-surface) 68%, transparent);
  }

  .archive-card h3,
  .thought-list h3 {
    margin-bottom: 0.75rem;
    font-size: 1.18rem;
  }

  .archive-card > p:not(.meta, .status),
  .thought-list article > p:last-child {
    color: var(--color-text-muted);
  }

  .status {
    margin-block: auto 0;
    padding-top: 2rem;
    color: var(--color-accent);
  }

  .thought-list article {
    padding-block: 1.5rem 2rem;
    border-top: 1px solid var(--color-border);
  }

  .thought-list article:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .about > p {
    grid-column: 2;
    white-space: pre-line;
  }

  .closing {
    padding-block: clamp(5rem, 12vw, 10rem);
    text-align: center;
  }

  .closing p:first-child {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.6rem);
  }

  .closing p:last-child {
    margin-bottom: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 58rem) {
    .hero {
      padding-block: 5.5rem 4.5rem;
    }

    h1 {
      max-width: 13em;
      font-size: clamp(2.8rem, 6.4vw, 4.25rem);
    }

    .section-rule {
      grid-template-columns: 1fr;
    }

    .introduction .section-index {
      grid-row: auto;
    }

    .archive-section .section-heading,
    .about .section-heading,
    .operating-system-entry,
    .card-grid,
    .thought-list,
    .about > p {
      grid-column: 1;
    }

    .card-grid-three {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 40rem) {
    .hero {
      padding-block: 4.5rem 4rem;
    }

    h1 {
      max-width: 11.5em;
      font-size: clamp(2.6rem, 11.2vw, 3.25rem);
      line-height: 1.14;
      letter-spacing: -0.025em;
    }

    .signature {
      text-align: right;
    }

    .card-grid-three {
      grid-template-columns: 1fr;
    }

    .archive-card {
      min-height: 15rem;
    }
  }
</style>
