---
import { site } from "../config/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentCard from "../components/ContentCard.astro";
import { getPublishedExperiments, getPublishedWorks, getPublishedWriting, selectFeatured } from "../lib/content";

const works = selectFeatured(await getPublishedWorks(), 2);
const writing = (await getPublishedWriting()).slice(0, 3);
const experiments = (await getPublishedExperiments()).slice(0, 3);
---

<BaseLayout>
  <section class="hero page-shell" aria-labelledby="hero-title">
    <p class="eyebrow">作品 · 思考 · 长期实验</p>
    <h1 id="hero-title">{site.hero}</h1>
    <p class="signature">{site.heroSignature}</p>
  </section>

  <section class="introduction page-shell section-rule" aria-labelledby="intro-title">
    <p class="section-index" aria-hidden="true">00</p>
    <div class="section-heading">
      <h2 id="intro-title">这是一个持续生长的档案。</h2>
    </div>
    <p class="lead">用来保存作品、记录思考、追踪长期实验，也持续向世界发出信号。这里不急于给出完整答案，只认真留下那些真实发生的过程。</p>
  </section>

  <section class="archive-section page-shell section-rule" aria-labelledby="works-title">
    <div class="section-heading">
      <p class="section-index" aria-hidden="true">01</p>
      <h2 id="works-title">进行中的项目</h2>
      <p>正在持续建设的长期项目。</p>
    </div>
    <div class="card-grid card-grid-three">{works.length ? works.map(({ id, data }) => <ContentCard headingLevel="h3" title={data.title} description={data.description} publishedAt={data.publishedAt} href={`/works/${id}/`} label={data.type} status={data.status} tags={data.tags} />) : <p class="empty">内容正在整理中。</p>}</div>
  </section>

  <section class="archive-section page-shell section-rule" aria-labelledby="thoughts-title">
    <div class="section-heading">
      <p class="section-index" aria-hidden="true">02</p>
      <h2 id="thoughts-title">最新文章</h2>
      <p>最近发布的正式写作。</p>
    </div>
    <div class="card-grid card-grid-three">{writing.length ? writing.map(({ id, data }) => <ContentCard headingLevel="h3" title={data.title} description={data.description} publishedAt={data.publishedAt} href={`/writing/${id}/`} label={data.category} tags={data.tags} />) : <p class="empty">内容正在整理中。</p>}</div>
  </section>

  <section class="archive-section page-shell section-rule" aria-labelledby="experiments-title">
    <div class="section-heading">
      <p class="section-index" aria-hidden="true">03</p>
      <h2 id="experiments-title">当前实验</h2>
      <p>正在时间里反复实践、学习与记录。</p>
    </div>
    <div class="card-grid card-grid-three">{experiments.length ? experiments.map(({ id, data }) => <ContentCard headingLevel="h3" title={data.title} description={data.description} publishedAt={data.publishedAt} href={`/experiments/${id}/`} label={data.cadence} status={data.status} tags={data.tags} />) : <p class="empty">内容正在整理中。</p>}</div>
  </section>

  <section class="about page-shell section-rule" aria-labelledby="about-title">
    <div class="section-heading">
      <p class="section-index" aria-hidden="true">04</p>
      <h2 id="about-title">关于</h2>
    </div>
    <p>{site.about}</p>
  </section>

  <section class="closing page-shell" aria-label="结束语">
    <p>{site.slogan}</p>
    <p>持续记录，持续创作，持续向世界发出微弱但真实的信号。</p>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: clamp(32rem, 72vh, 48rem);
    padding-block: clamp(6rem, 13vw, 11rem) 5rem;
  }

  .eyebrow,
  .meta,
  .status,
  .section-index {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
  }

  .eyebrow {
    margin-bottom: 2.5rem;
  }

  h1 {
    max-width: 14em;
    margin-bottom: 2.5rem;
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6.4vw, 5.75rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    white-space: pre-line;
  }

  .signature {
    margin-left: min(48%, 28rem);
    color: var(--color-text-muted);
  }

  .section-rule {
    display: grid;
    grid-template-columns: minmax(9rem, 0.75fr) minmax(0, 2.25fr);
    gap: 2rem 4rem;
    padding-block: var(--space-section);
    border-top: 1px solid var(--color-border);
  }

  .introduction .section-index {
    grid-row: 1 / 3;
  }

  .lead,
  .about > p {
    max-width: var(--content-width);
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    line-height: 1.75;
  }

  .section-heading h2 {
    margin-bottom: 0.6rem;
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .section-heading > p:last-child {
    margin-bottom: 0;
    color: var(--color-text-muted);
  }

  .archive-section .section-heading,
  .about .section-heading {
    grid-column: 1;
  }

  .card-grid,
  .thought-list {
    grid-column: 2;
  }

  .empty { grid-column: 1 / -1; padding: 3rem 1.5rem; border-block: 1px solid var(--color-border); color: var(--color-text-muted); text-align: center; }

  .card-grid {
    display: grid;
    gap: 1rem;
  }

  .card-grid-three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .archive-card {
    display: flex;
    min-height: 18rem;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-small);
    background: color-mix(in srgb, var(--color-surface) 68%, transparent);
  }

  .archive-card h3,
  .thought-list h3 {
    margin-bottom: 0.75rem;
    font-size: 1.18rem;
  }

  .archive-card > p:not(.meta, .status),
  .thought-list article > p:last-child {
    color: var(--color-text-muted);
  }

  .status {
    margin-block: auto 0;
    padding-top: 2rem;
    color: var(--color-accent);
  }

  .thought-list article {
    padding-block: 1.5rem 2rem;
    border-top: 1px solid var(--color-border);
  }

  .thought-list article:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .about > p {
    grid-column: 2;
    white-space: pre-line;
  }

  .closing {
    padding-block: clamp(5rem, 12vw, 10rem);
    text-align: center;
  }

  .closing p:first-child {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.6rem);
  }

  .closing p:last-child {
    margin-bottom: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 58rem) {
    .section-rule {
      grid-template-columns: 1fr;
    }

    .introduction .section-index {
      grid-row: auto;
    }

    .archive-section .section-heading,
    .about .section-heading,
    .card-grid,
    .thought-list,
    .about > p {
      grid-column: 1;
    }

    .card-grid-three {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 40rem) {
    .hero {
      min-height: 30rem;
      padding-block: 5rem 4rem;
    }

    h1 {
      font-size: clamp(2.25rem, 11vw, 3.5rem);
      letter-spacing: -0.025em;
    }

    .signature {
      margin-left: 0;
      text-align: right;
    }

    .card-grid-three {
      grid-template-columns: 1fr;
    }

    .archive-card {
      min-height: 15rem;
    }
  }
</style>
