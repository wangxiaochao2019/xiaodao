---
import { render, type CollectionEntry } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";
import { canonicalFor, getPublishedProjects } from "../../lib/content";
export async function getStaticPaths() {
  const entries = await getPublishedProjects();
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}
const { entry } = Astro.props as { entry: CollectionEntry<"projects"> };
const { Content } = await render(entry);
---
<ContentLayout title={entry.data.title} description={entry.data.description} publishedTime={entry.data.publishedAt} modifiedTime={entry.data.updatedAt} collectionLabel="项目档案" backHref="/projects/" backLabel="项目" canonical={canonicalFor(`/projects/${entry.id}/`)} metadata={[{ label: "类型", value: entry.data.type }, { label: "年份", value: String(entry.data.year) }, { label: "状态", value: entry.data.status }]} tags={entry.data.tags}>
  <Content />
</ContentLayout>
