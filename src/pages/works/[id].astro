---
import { render, type CollectionEntry } from "astro:content";
import ContentDetail from "../../components/ContentDetail.astro";
import { canonicalFor, getPublishedWorks } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getPublishedWorks();
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"works"> };
const { Content } = await render(entry);
---

<ContentDetail
  title={entry.data.title}
  description={entry.data.description}
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
  backHref="/works/"
  backLabel="作品"
  canonical={canonicalFor(`/works/${entry.id}/`)}
  meta={[entry.data.type, String(entry.data.year), entry.data.status]}
  tags={entry.data.tags}
>
  <Content />
</ContentDetail>
