---
import { render, type CollectionEntry } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";
import { canonicalFor, getPublishedWorks } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getPublishedWorks();
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"works"> };
const { Content } = await render(entry);
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  publishedTime={entry.data.publishedAt}
  modifiedTime={entry.data.updatedAt}
  collectionLabel="作品档案"
  backHref="/works/"
  backLabel="作品"
  canonical={canonicalFor(`/works/${entry.id}/`)}
  metadata={[{ label: "类型", value: entry.data.type }, { label: "年份", value: String(entry.data.year) }, { label: "状态", value: entry.data.status }]}
  tags={entry.data.tags}
>
  <Content />
</ContentLayout>
