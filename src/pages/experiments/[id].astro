---
import { render, type CollectionEntry } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";
import { canonicalFor, formatDate, getPublishedExperiments } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getPublishedExperiments();
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"experiments"> };
const { Content } = await render(entry);
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  publishedTime={entry.data.publishedAt}
  modifiedTime={entry.data.updatedAt}
  collectionLabel="长期实验"
  backHref="/experiments/"
  backLabel="长期实验"
  canonical={canonicalFor(`/experiments/${entry.id}/`)}
  metadata={[{ label: "状态", value: entry.data.status }, { label: "开始", value: formatDate(entry.data.startedAt) }, ...(entry.data.cadence ? [{ label: "节奏", value: entry.data.cadence }] : [])]}
  tags={entry.data.tags}
>
  <Content />
</ContentLayout>
