---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="页面没有找到" description="这个页面可能已经移动、改名，或者暂时不存在。" noindex>
  <section class="not-found page-shell" aria-labelledby="not-found-title">
    <p class="eyebrow">404</p>
    <h1 id="not-found-title">页面没有找到</h1>
    <p>它可能已经移动、改名，或者暂时不存在。</p>
    <nav aria-label="返回站点">
      <a class="primary-link" href="/">返回首页</a>
      <a href="/works/">浏览作品</a>
      <a href="/writing/">阅读思考</a>
      <a href="/experiments/">查看实验</a>
    </nav>
  </section>
</BaseLayout>

<style>
  .not-found { min-height: 62vh; padding-block: clamp(5rem, 12vw, 10rem); }
  .eyebrow { color: var(--color-text-muted); font-size: .78rem; letter-spacing: .12em; }
  h1 { margin-block: 1.5rem 1rem; font-family: var(--font-serif); font-size: clamp(2.6rem, 6vw, 5rem); }
  .not-found > p:not(.eyebrow) { max-width: 36rem; color: var(--color-text-muted); }
  nav { display: flex; flex-wrap: wrap; gap: .75rem 1.5rem; margin-top: 2.5rem; }
  .primary-link { color: var(--color-accent); font-weight: 700; }
</style>
