---
import { render, type CollectionEntry } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";
import { canonicalFor, getPublishedWriting } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getPublishedWriting();
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"writing"> };
const { Content } = await render(entry);
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  publishedTime={entry.data.publishedAt}
  modifiedTime={entry.data.updatedAt}
  collectionLabel="思考记录"
  backHref="/writing/"
  backLabel="思考"
  canonical={canonicalFor(`/writing/${entry.id}/`)}
  metadata={[{ label: "分类", value: entry.data.category }, ...(entry.data.series ? [{ label: "系列", value: entry.data.series }] : [])]}
  tags={entry.data.tags}
>
  <Content />
</ContentLayout>
