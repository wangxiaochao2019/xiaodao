---
import { render, type CollectionEntry } from "astro:content";
import ContentDetail from "../../components/ContentDetail.astro";
import { canonicalFor, getPublishedWriting } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getPublishedWriting();
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"writing"> };
const { Content } = await render(entry);
---

<ContentDetail
  title={entry.data.title}
  description={entry.data.description}
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
  backHref="/writing/"
  backLabel="思考"
  canonical={canonicalFor(`/writing/${entry.id}/`)}
  meta={[entry.data.category, ...(entry.data.series ? [entry.data.series] : [])]}
  tags={entry.data.tags}
>
  <Content />
</ContentDetail>
