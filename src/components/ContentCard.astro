---
import { formatDate, toDateTime } from "../lib/content";

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  href?: string;
  label?: string;
  status?: string;
  tags?: string[];
  headingLevel?: "h2" | "h3";
}

const { title, description, publishedAt, href, label, status, tags = [], headingLevel = "h2" } = Astro.props;
const Heading = headingLevel;
---

<article class="content-card">
  <div class="content-card__meta">
    {label && <span>{label}</span>}
    <time datetime={toDateTime(publishedAt)}>{formatDate(publishedAt)}</time>
  </div>
  <Heading class="content-card__title">
    {href ? <a href={href}>{title}</a> : title}
  </Heading>
  <p class="content-card__description">{description}</p>
  {(status || tags.length > 0) && (
    <footer class="content-card__footer">
      {status && <span class="content-card__status">{status}</span>}
      {tags.length > 0 && <ul aria-label="标签">{tags.map((tag) => <li>{tag}</li>)}</ul>}
    </footer>
  )}
</article>

<style>
  .content-card { display: flex; min-height: 18rem; flex-direction: column; padding: 1.5rem; border: 1px solid var(--color-border); border-radius: var(--radius-small); background: color-mix(in srgb, var(--color-surface) 68%, transparent); }
  .content-card__meta { display: flex; flex-wrap: wrap; justify-content: space-between; gap: .35rem 1rem; color: var(--color-text-muted); font-size: .78rem; letter-spacing: .08em; }
  .content-card__title { margin-block: 1.4rem .75rem; font-family: var(--font-serif); font-size: 1.35rem; overflow-wrap: anywhere; }
  .content-card__description { color: var(--color-text-muted); }
  .content-card__footer { display: flex; flex-wrap: wrap; align-items: end; justify-content: space-between; gap: 1rem; margin-top: auto; padding-top: 2rem; }
  .content-card__status { color: var(--color-accent); font-size: .82rem; }
  ul { display: flex; flex-wrap: wrap; gap: .35rem .75rem; margin: 0; padding: 0; color: var(--color-text-muted); font-size: .75rem; list-style: none; }
  li::before { content: "#"; }
</style>
