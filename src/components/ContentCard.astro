---
import { formatDate, toDateTime } from "../lib/content";

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  href?: string;
  label?: string;
  status?: string;
  tags?: string[];
  headingLevel?: "h2" | "h3";
}

const { title, description, publishedAt, href, label, status, tags = [], headingLevel = "h2" } = Astro.props;
const Heading = headingLevel;
---

<article class="content-card">
  <div class="content-card__meta">
    {label && <span>{label}</span>}
    <time datetime={toDateTime(publishedAt)}>{formatDate(publishedAt)}</time>
  </div>
  <Heading class="content-card__title">
    {href ? <a href={href}>{title}</a> : title}
  </Heading>
  <p class="content-card__description">{description}</p>
  {(status || tags.length > 0) && (
    <footer class="content-card__footer">
      {status && <span class="content-card__status">{status}</span>}
      {tags.length > 0 && <ul aria-label="标签">{tags.map((tag) => <li>{tag}</li>)}</ul>}
    </footer>
  )}
</article>

<style>
  .content-card { display: flex; min-height: 17rem; flex-direction: column; background: transparent; }
  .content-card__meta { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: .35rem 1.25rem; color: var(--color-text-muted); font-size: .78rem; letter-spacing: .08em; }
  .content-card__meta time { flex: 0 0 auto; }
  .content-card__title { margin-block: 1.75rem .9rem; font-family: var(--font-serif); font-size: 1.35rem; overflow-wrap: anywhere; }
  .content-card__title a { text-decoration: none; }
  .content-card__title a:hover { color: var(--color-accent); text-decoration: underline; text-decoration-thickness: .08em; text-underline-offset: .25em; }
  .content-card__title a:focus-visible { color: var(--color-accent); text-decoration: underline; text-decoration-thickness: .08em; text-underline-offset: .25em; }
  .content-card__description { color: var(--color-text-muted); }
  .content-card__footer { display: flex; flex-wrap: wrap; align-items: end; justify-content: space-between; gap: 1rem 1.5rem; margin-top: auto; padding-top: 2.25rem; }
  .content-card__status { color: var(--color-accent); font-size: .82rem; }
  ul { display: flex; flex-wrap: wrap; gap: .35rem .75rem; margin: 0; padding: 0; color: var(--color-text-muted); font-size: .75rem; list-style: none; }
  li::before { content: "#"; }

  @media (min-width: 58.01rem) {
    :global(.card-grid-three) .content-card { min-height: 16rem; padding: 0 1.35rem 1.5rem; border-top: 0; border-left: 1px solid var(--color-border); }
    :global(.card-grid-three) .content-card:first-child { padding-left: 0; border-left: 0; }
    :global(.card-grid-three) .content-card:last-child { padding-right: 0; }
  }

  @media (max-width: 40rem) {
    .content-card { min-height: 0; }
    .content-card__title { margin-top: 1.5rem; }
    .content-card__footer { padding-top: 2rem; }
  }
</style>
