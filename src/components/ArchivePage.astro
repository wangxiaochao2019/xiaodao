---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentCard from "./ContentCard.astro";

interface Item { title: string; description: string; publishedAt: Date; href: string; label?: string; status?: string; tags?: string[]; }
interface Props { title: string; description: string; canonical?: URL; items: Item[]; }
const { title, description, canonical, items } = Astro.props;
---
<BaseLayout title={title} description={description} canonical={canonical}>
  <header class="archive-hero page-shell">
    <p>公开档案</p><h1>{title}</h1><p class="lead">{description}</p>
  </header>
  <section class="archive-list page-shell" aria-label={`${title}列表`}>
    {items.length ? <div class="grid">{items.map((item) => <ContentCard {...item} />)}</div> : <p class="empty">内容正在整理中。</p>}
  </section>
</BaseLayout>
<style>
  .archive-hero { padding-block: clamp(5rem, 11vw, 9rem) clamp(3rem, 6vw, 5rem); }
  .archive-hero > p:first-child { color: var(--color-text-muted); font-size: .78rem; letter-spacing: .12em; }
  h1 { margin-bottom: 1rem; font-family: var(--font-serif); font-size: clamp(2.6rem, 6vw, 5rem); }
  .lead { max-width: 38rem; color: var(--color-text-muted); font-size: 1.12rem; }
  .archive-list { padding-block: 0 var(--space-section); }
  .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); column-gap: clamp(4rem, 6vw, 5rem); row-gap: clamp(4.5rem, 7vw, 5.5rem); }
  .empty { padding: 4rem 1.5rem; border-block: 1px solid var(--color-border); color: var(--color-text-muted); text-align: center; }
  @media (max-width: 58rem) { .grid { column-gap: 3rem; row-gap: 4.5rem; } }
  @media (max-width: 40rem) { .grid { grid-template-columns: 1fr; row-gap: 3.75rem; } }
</style>
