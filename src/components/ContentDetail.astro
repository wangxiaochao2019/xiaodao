---
import { formatDate, toDateTime } from "../lib/content";
import BaseLayout from "../layouts/BaseLayout.astro";
interface Props { title: string; description: string; publishedAt: Date; updatedAt?: Date; backHref: string; backLabel: string; canonical?: URL; meta?: string[]; tags?: string[]; }
const { title, description, publishedAt, updatedAt, backHref, backLabel, canonical, meta = [], tags = [] } = Astro.props;
const showUpdatedAt = updatedAt && updatedAt.getTime() > publishedAt.getTime();
---
<BaseLayout title={title} description={description} canonical={canonical}>
  <article class="detail page-shell">
    <p class="back"><a href={backHref}>← 返回{backLabel}</a></p>
    <header>
      <p class="dates"><time datetime={toDateTime(publishedAt)}>发布于 {formatDate(publishedAt)}</time>{showUpdatedAt && <time datetime={toDateTime(updatedAt)}>更新于 {formatDate(updatedAt)}</time>}</p>
      <h1>{title}</h1><p>{description}</p>
      {(meta.length > 0 || tags.length > 0) && <div class="metadata">{meta.map((item) => <span>{item}</span>)}{tags.map((tag) => <span>#{tag}</span>)}</div>}
    </header>
    <div class="prose"><slot /></div>
  </article>
</BaseLayout>
<style>
  .detail { padding-block: clamp(4rem, 10vw, 8rem); }
  .back, .dates, .metadata { color: var(--color-text-muted); font-size: .82rem; }
  .dates, .metadata { display: flex; flex-wrap: wrap; gap: .35rem 1rem; }
  .dates { margin: 0; }
  header { max-width: var(--content-width); margin-block: 3rem 4rem; }
  h1 { margin-block: 1rem; font-family: var(--font-serif); font-size: clamp(2.25rem, 5vw, 4.4rem); overflow-wrap: anywhere; }
  header > p { color: var(--color-text-muted); font-size: 1.12rem; }
  .metadata { margin-top: 1.5rem; }
  .prose { max-width: var(--content-width); padding-top: 2rem; border-top: 1px solid var(--color-border); font-family: var(--font-serif); font-size: 1.1rem; }
</style>
