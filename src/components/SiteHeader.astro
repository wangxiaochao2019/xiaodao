---
import { site } from "../config/site";
const pathname = Astro.url.pathname;
const isCurrent = (href: string) => href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="site-header">
  <div class="page-shell header-inner">
    <a class="wordmark" href="/" aria-label={`${site.author}，返回首页`}>{site.author}</a>
    <nav aria-label="主导航">
      <ul>
        {site.navigation.map((item) => (
          <li><a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem 3rem;
    min-height: 5.5rem;
    padding-block: 0.9rem;
  }

  .wordmark {
    flex: 0 0 auto;
    font-family: var(--font-serif);
    font-size: 1.55rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-decoration: none;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.25rem clamp(1.2rem, 1.7vw, 1.9rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  nav a {
    display: inline-block;
    min-height: 2.75rem;
    padding-block: 0.55rem;
    color: color-mix(in srgb, var(--color-text) 78%, var(--color-bg));
    font-size: 0.94rem;
    font-weight: 500;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--color-text);
  }

  nav a[aria-current="page"] { color: var(--color-text); text-decoration: underline; text-decoration-color: var(--color-accent); text-decoration-thickness: .09em; text-underline-offset: .55em; }

  @media (max-width: 64rem) {
    .header-inner { gap-inline: 2rem; }
    ul { gap-inline: 1.15rem; }
    nav a { font-size: .88rem; }
  }

  @media (max-width: 36rem) {
    .header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.55rem;
      padding-block: 1.1rem 1rem;
    }

    ul {
      justify-content: flex-start;
      gap: 0 1.05rem;
    }

    nav a { min-height: 2.35rem; padding-block: .4rem; }
  }
</style>
